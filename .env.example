# Database — see https://www.prisma.io/docs/orm/prisma-client/setup-and-configuration/databases-connections#external-connection-poolers
#
# DATABASE_URL — Used by the running API for queries. Use your host’s *pooled* URL when available
#   (e.g. Neon hostname with “-pooler” and add &pgbouncer=true&connect_timeout=15 to the query string).
#
# DIRECT_URL — Used by `prisma migrate` / `prisma db` only. Must point at Postgres *without* PgBouncer
#   transaction pooling (e.g. Neon non-pooler host). If you have a single non-pooled URL, set both vars the same.
#
DATABASE_URL="postgresql://postgres:password@localhost:5432/rayenna_crm?schema=public"
DIRECT_URL="postgresql://postgres:password@localhost:5432/rayenna_crm?schema=public"

# JWT Configuration
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Server Configuration
PORT=3000
NODE_ENV=development

# Frontend (production - required for CORS and password reset emails)
# FRONTEND_URL=https://your-frontend-domain.com

# Optional: Error tracking (backend)
# SENTRY_DSN=https://...@sentry.io/...

# Optional: File uploads (Cloudinary). Omit to disable uploads.
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# Optional: AI proposal generation
# OPENAI_API_KEY=sk-...

# File Upload Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
